# Facebook Messenger Configuration
# Copy this file to .env and fill in your values
# Get credentials from: https://developers.facebook.com

PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here
VERIFY_TOKEN=your_custom_verify_token_here

# Anthropic API (for AI responses)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Notes:
# 1. Rename this file to .env (remove .example)
# 2. NEVER commit your .env file to GitHub
# 3. Add .env to your .gitignore
